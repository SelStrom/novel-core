{
  "max_fix_iterations": 10,
  "max_patch_size_lines": 200,
  "break_tests": {
    "enabled": true,
    "generate_edge_cases": true,
    "generate_adversarial": true
  },
  "test_execution": {
    "editmode_first": true,
    "playmode_if_needed": true,
    "timeout_seconds": 300
  },
  "commit": {
    "auto_commit": false,
    "require_manual_approval": true
  },
  "theory": {
    "min_confidence_threshold": 50,
    "require_diagnostic_tests_if_close": true,
    "confidence_difference_threshold": 20
  },
  "logging": {
    "verbose": true,
    "save_agent_logs": true,
    "preserve_iterations": true
  },
  "cleanup": {
    "archive_to_memory": true,
    "remove_temp_logs": true,
    "preserve_days": 30
  }
}
